#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#C2
:C2 rdf:type owl:Class ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :is_owned_by ;
                      owl:someValuesFrom :Operador
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :manages ;
                      owl:someValuesFrom :Nodo
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :estado_operativo ;
                      owl:someValuesFrom xsd:string
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :graficas ;
                      owl:someValuesFrom xsd:string
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :responsable ;
                      owl:someValuesFrom xsd:string
                    ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Datos
:Datos rdf:type owl:Class ;
       rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :is_used_by ;
                         owl:someValuesFrom :Organizacion
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :fecha_hora ;
                         owl:someValuesFrom xsd:string
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :tamaño_bytes ;
                         owl:someValuesFrom xsd:integer
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :tipo ;
                         owl:someValuesFrom xsd:string
                       ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Dron
:Dron rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :generates ;
                        owl:someValuesFrom :Datos
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :is_operated_by ;
                        owl:someValuesFrom :Nodo
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :is_operated_by ;
                        owl:someValuesFrom :Piloto
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :provides_data_to ;
                        owl:someValuesFrom :Servidor
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :uses_model ;
                        owl:someValuesFrom :Modelo
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :autonomia_vuelo ;
                        owl:someValuesFrom xsd:decimal
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :carga_util ;
                        owl:someValuesFrom xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :estado_operativo ;
                        owl:someValuesFrom xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :id ;
                        owl:someValuesFrom xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :tipo ;
                        owl:someValuesFrom xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :ubicacion ;
                        owl:someValuesFrom xsd:string
                      ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Modelo
:Modelo rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :provides_visualization ;
                          owl:someValuesFrom :C2
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :algoritmo ;
                          owl:someValuesFrom xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hiperparametros ;
                          owl:someValuesFrom xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :historial ;
                          owl:someValuesFrom xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :metricas ;
                          owl:someValuesFrom xsd:string
                        ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Nodo
:Nodo rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :interacts_with ;
                        owl:someValuesFrom :Nodo
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :is_backed_up ;
                        owl:someValuesFrom :Nodo
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :is_managed_by ;
                        owl:someValuesFrom :C2
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :is_part_of ;
                        owl:someValuesFrom :Organizacion
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :capacidad_procesamiento ;
                        owl:someValuesFrom xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :funcion_c2 ;
                        owl:someValuesFrom xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :interaccion_con ;
                        owl:someValuesFrom xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :metricas ;
                        owl:someValuesFrom xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :nombre ;
                        owl:someValuesFrom xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :pertenece_a ;
                        owl:someValuesFrom owl:rational
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :redundancia ;
                        owl:someValuesFrom xsd:string
                      ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Operador
:Operador rdf:type owl:Class ;
          rdfs:subClassOf :Persona ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :capacitacion ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :especializacion ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :especialización ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :estado_operativo ;
                            owl:someValuesFrom xsd:string
                          ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Organizacion
:Organizacion rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :controls ;
                                owl:someValuesFrom :Nodo
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :interacts_with ;
                                owl:someValuesFrom :Organizacion
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :capacidades_organizacion ;
                                owl:someValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :interaccion_con ;
                                owl:someValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :miembros ;
                                owl:someValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :mision ;
                                owl:someValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :nodos_controlados ;
                                owl:someValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :nombre ;
                                owl:someValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :tipo_organizacion ;
                                owl:someValuesFrom xsd:string
                              ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Persona
:Persona rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :especializacion ;
                           owl:someValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :especialización ;
                           owl:someValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :nombre ;
                           owl:someValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :rol_puesto ;
                           owl:someValuesFrom xsd:string
                         ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Piloto
:Piloto rdf:type owl:Class ;
        rdfs:subClassOf :Persona ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :belongs_to ;
                          owl:someValuesFrom :Organizacion
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :controls ;
                          owl:someValuesFrom :Dron
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :compatibilidad_sistemas ;
                          owl:someValuesFrom xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :estado_operativo ;
                          owl:someValuesFrom xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :horas_vuelo_acumuladas ;
                          owl:someValuesFrom xsd:nonNegativeInteger
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :licencia ;
                          owl:someValuesFrom xsd:string
                        ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Propietario
:Propietario rdf:type owl:Class ;
             rdfs:subClassOf :Persona ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :autoridad_legal ;
                               owl:someValuesFrom xsd:string
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :superior_directo ;
                               owl:someValuesFrom xsd:string
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :unidad_militar ;
                               owl:someValuesFrom xsd:string
                             ] .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Servidor
:Servidor rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :hosts_model ;
                            owl:someValuesFrom :Modelo
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :is_owned_by ;
                            owl:someValuesFrom :Propietario
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :stores ;
                            owl:someValuesFrom :Datos
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :capacidad_almacenamiento ;
                            owl:someValuesFrom xsd:integer
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :direccion_ip ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :estado_operativo ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :modelo_global ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :ubicacion ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :velocidad_procesamiento ;
                            owl:someValuesFrom xsd:decimal
                          ] .


###  http://www.w3.org/2002/07/owl#EquivalentProperty
owl:EquivalentProperty rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Alemania_País
:Alemania_País rdf:type owl:NamedIndividual ,
                        :Organizacion ;
               :controls :Nodo-3 ,
                         :Nodo-6 ;
               :interacts_with :Francia_País ;
               :mision "Defensa" ;
               :nombre "Alemania" ;
               :tipo_organizacion "País" .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Batallón-1
:Batallón-1 rdf:type owl:NamedIndividual ,
                     :Propietario ;
            :superior_directo "Coronel A" ;
            :unidad_militar "Batallón-1" .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Batallón-10
:Batallón-10 rdf:type owl:NamedIndividual ,
                      :Propietario ;
             :superior_directo "Capitán J" ;
             :unidad_militar "Batallón-10" .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Batallón-4
:Batallón-4 rdf:type owl:NamedIndividual ,
                     :Propietario ;
            :superior_directo "Capitán D" ;
            :unidad_militar "Batallón-4" .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#Batallón-7
:Batallón-7 rdf:type owl:NamedIndividual ,
                     :Propietario ;
            :superior_directo "Coronel G" ;
            :unidad_militar "Batallón-7" .


