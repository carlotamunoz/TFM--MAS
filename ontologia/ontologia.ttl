@prefix : <http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#> .

<http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2002/07/owl#DatatypeProperty
owl:DatatypeProperty rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#belongs_to
:belongs_to rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#controls
:controls rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#generates
:generates rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#hosts_model
:hosts_model rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#interacts_with
:interacts_with rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#is_backed_up
:is_backed_up rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#is_managed_by
:is_managed_by rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#is_operated_by
:is_operated_by rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#is_operated_in
:is_operated_in rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#is_owned_by
:is_owned_by rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#is_part_of
:is_part_of rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#is_used_by
:is_used_by rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#manages
:manages rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#provides_data_to
:provides_data_to rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#provides_visualization
:provides_visualization rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#stores
:stores rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/carlo/ontologies/2024/10/untitled-ontology-4#uses_model
:uses_model rdf:type owl:ObjectProperty .


